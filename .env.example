# ═══════════════════════════════════════════════════
# AgentVerse — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ─── LLM — 0G Compute Router (decentralized, OpenAI-compatible) ───
LLM_PROVIDER=0g
LLM_BASE_URL=https://router-api.0g.ai/v1
LLM_API_KEY=sk-your_0g_compute_key
LLM_MODEL=zai-org/GLM-5-FP8

# ─── LLM — OpenAI fallback (optional) ───
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_key

# ─── 0G Chain ───
PRIVATE_KEY=0x_your_deployer_private_key
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602

# ─── 0G Storage ───
STORAGE_INDEXER_URL=your_storage_indexer_endpoint
STORAGE_KV_NODE_URL=your_kv_node_endpoint

# ─── AXL P2P Nodes ───
AXL_NODE_A_PORT=9002
AXL_NODE_B_PORT=9012

# ─── KeeperHub + x402 Payments ───
KH_API_KEY=kh_your_organization_api_key
# Get key: app.keeperhub.com → Settings → API Keys → Organisation tab
# Agentic wallet: npx -p @keeperhub/wallet keeperhub-wallet add
# Wallet config stored at ~/.keeperhub/wallet.json (auto-created)

# ─── Contract Addresses (filled after deployment) ───
AGENT_NFT_ADDRESS=
TASK_MANAGER_ADDRESS=
AUCTION_ADDRESS=

# ─── Backend ───
PORT=3001

# ─── Frontend ───
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_OG_CHAIN_ID=16602
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai
